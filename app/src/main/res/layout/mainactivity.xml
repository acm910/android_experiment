<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mainShellRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FBFCFE"
    android:orientation="vertical"
    android:weightSum="100">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/mainContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="91" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="7dp"
        android:layout_weight="9"
        android:background="#F8FAFD"
        android:elevation="10dp"
        android:minHeight="64dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        app:itemBackground="@drawable/bg_bottom_nav_item"
        app:itemHorizontalTranslationEnabled="false"
        app:itemIconSize="22dp"
        app:itemIconTint="@color/bottom_nav_item_color"
        app:itemPaddingBottom="4dp"
        app:itemPaddingTop="6dp"
        app:itemRippleColor="@android:color/transparent"
        app:itemTextAppearanceActive="@style/TextAppearance.Experiment.BottomNav.Active"
        app:itemTextAppearanceInactive="@style/TextAppearance.Experiment.BottomNav.Inactive"
        app:itemTextColor="@color/bottom_nav_item_color"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/menu_main_bottom_nav" />
</LinearLayout>
