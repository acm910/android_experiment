<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/userRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FBFCFE"
    android:orientation="vertical">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#F3F6FB"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/user_bar_title"
            android:textColor="#223046"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:padding="16dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:orientation="horizontal"
                android:padding="16dp">
                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:contentDescription="@string/user_avatar_desc"
                    android:src="@mipmap/ic_launcher_round" />
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_marginStart="14dp"
                    android:gravity="center_vertical"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/user_name_demo"
                        android:textColor="#223046"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/user_subtitle_demo"
                        android:textColor="#7B8AA0"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>
            <TextView
                android:id="@+id/btnEditProfile"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_item_press_darken"
                android:gravity="center_vertical"
                android:paddingStart="14dp"
                android:text="@string/user_action_edit_profile"
                android:textColor="#2D3B50"
                android:textSize="15sp" />
            <TextView
                android:id="@+id/btnAccountSafe"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="1dp"
                android:background="@drawable/bg_item_press_darken"
                android:gravity="center_vertical"
                android:paddingStart="14dp"
                android:text="@string/user_action_account"
                android:textColor="#2D3B50"
                android:textSize="15sp" />
            <TextView
                android:id="@+id/btnMySubmissions"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="1dp"
                android:background="@drawable/bg_item_press_darken"
                android:gravity="center_vertical"
                android:paddingStart="14dp"
                android:text="@string/user_action_submission"
                android:textColor="#2D3B50"
                android:textSize="15sp" />
            <TextView
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_item_press_darken"
                android:gravity="center_vertical"
                android:paddingStart="14dp"
                android:text="@string/user_action_logout"
                android:textColor="#D24A4A"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
