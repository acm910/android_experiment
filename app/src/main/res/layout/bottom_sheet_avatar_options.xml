<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#FFFFFF"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="12dp"
    android:paddingEnd="16dp"
    android:paddingBottom="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingTop="4dp"
        android:paddingBottom="12dp"
        android:text="@string/avatar_sheet_title"
        android:textColor="#223046"
        android:textSize="16sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnPickFromGallery"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_action_button_light"
        android:text="@string/avatar_sheet_pick_gallery"
        android:textAllCaps="false"
        android:textColor="#2D3B50"
        android:textSize="15sp" />

    <Button
        android:id="@+id/btnTakePhoto"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_action_button_light"
        android:text="@string/avatar_sheet_take_photo"
        android:textAllCaps="false"
        android:textColor="#2D3B50"
        android:textSize="15sp" />

    <Button
        android:id="@+id/btnCancelAvatarAction"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:layout_marginTop="14dp"
        android:background="@android:color/transparent"
        android:text="@string/avatar_sheet_cancel"
        android:textAllCaps="false"
        android:textColor="#7B8AA0"
        android:textSize="14sp" />

</LinearLayout>

